{
    "name": "MCP GitLab Issues Dev",
    "build": {
        "dockerfile": "Dockerfile",
        "context": ".."
    },
    "forwardPorts": [8000],
    "postCreateCommand": "pip install --no-cache-dir -r requirements.txt",
    "postStartCommand": "/workspaces/mcp_gitlab_list_issues/start_server.sh",
    "customizations": {
        "vscode": {
            "extensions": [
                "ms-python.python",
                "ms-vscode.vscode-json",
                "ms-vscode-remote.remote-containers"
            ]
        }
    }
}