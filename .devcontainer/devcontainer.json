{
    "name": "MCP GitLab Issues Dev",
    "dockerComposeFile": [
        "../docker-compose.yml"
    ],
    "service": "mcp-gitlab",
    "workspaceFolder": "/app",
    "overrideCommand": false,
    "forwardPorts": [8000],
    "customizations": {
        "vscode": {
            "extensions": [
                "ms-python.python",
                "ms-vscode.vscode-json",
                "ms-vscode-remote.remote-containers"
            ]
        }
    }
}